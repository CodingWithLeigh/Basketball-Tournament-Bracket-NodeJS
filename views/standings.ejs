<%- include("./partials/nav.ejs"), ({ title: title, status: status }) %>

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    padding:30px;
}

.cointainer{
    margin-top:2%;
    background:white;
    border-radius:18px;
    padding:30px;
    box-shadow:0 10px 25px rgba(0,0,0,.08);
}

.left{
    display:flex;
    align-items:center;
    gap:10px;
    margin-bottom:30px;
}

.left label{
    font-weight:bold;
    color:#444;
}

.left select{
    padding:10px 15px;
    border-radius:8px;
    border:1px solid #ccc;
    outline:none;
    cursor:pointer;
}

.middle{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(260px,1fr));
    gap:20px;
}

.card{
    background:#fafafa;
    border:1px solid #e6e6e6;
    border-radius:15px;
    padding:20px;
    transition:.25s;
    text-align:center;
}

.card:hover{
    transform:translateY(-5px);
    box-shadow:0 10px 20px rgba(0,0,0,.08);
}

.card h3{
    margin-bottom:15px;
    color:#1f2937;
    font-size:24px;
}

.card a{
    margin:6px 0;
    color:#555;
}

.record{
    display:flex;
    justify-content:center;
    gap:20px;
    margin-top:15px;
    font-weight:bold;
}

.win{
    color:#16a34a;
}

.loss{
    color:#dc2626;
}

@view-transition {
            navigation: auto;
        }

        ::view-transition-old(root) {
            animation: fade-out .5s ease;
        }

        ::view-transition-new(root) {
            animation: fade-in .5s ease;
        }

        @keyframes fade-out {
            from { opacity: 1; }
            to { opacity: 0; }
        }

        @keyframes fade-in {
            from { opacity: 0; }
            to { opacity: 1; }
        }

</style>

<div class="cointainer">
<div class="left">
<label for="seasons">Season:</label>
<select name="seasons" id="seasons">
</select>

</div>

<div class="middle">
</div>

</div>

<script>

const seasons = document.getElementById("seasons")

async function getValue() {
const data = await fetch("/api/seasons")
const response = await data.json()

Object.keys(response.seasons).forEach((seasonKey) => {
const seasonData = response.seasons[seasonKey]; // This is the inner object
    
const option = document.createElement('option');
option.value = seasonKey;           // e.g., "season_1"
option.text = seasonData;     // Accessing the inner property, e.g., "Winter 2026"
    
seasons.appendChild(option);
})

}

getValue()

async function success(value) {

const data = await fetch("/api/standings/" + value)
const response = await data.json()

const container = document.querySelector('.middle');

container.innerHTML = "";

Object.entries(response).forEach(([team, info]) => {
  const card = document.createElement('div');
  
  card.classList.add('card');
  
  card.innerHTML = `
    <h3><a href="/games/${info.id}">${team}</a></h3>
    <a><strong>Player:</strong> ${info.player}</a>
    <a><strong>Wins:</strong> ${info.wins}</a>
    <a><strong>Losses:</strong> ${info.loss}</a>
  `;
  
  container.appendChild(card);
});

}

seasons.addEventListener('change', (event) => {
    const value = event.target.value;
    success(value);
  });

success("season1")

</script>

