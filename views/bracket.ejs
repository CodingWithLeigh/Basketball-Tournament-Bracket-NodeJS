<%- include("./partials/nav.ejs"), ({ title: title, status: status }) %>

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    padding:30px;
}

.cointainer{
    margin-top:2%;
    background:white;
    border-radius:18px;
    padding:30px;
    box-shadow:0 10px 25px rgba(0,0,0,.08);
}

.bracket{
    display:grid;
    grid-template-columns:repeat(4,220px);
    gap:40px;
    align-items:center;
    justify-content: center;
}

.round{
    display:flex;
    flex-direction:column;
    align-items:center;
    gap:30px;
}

.match{
    width:210px;
    min-height:70px;
    background:#ddd;
    border-radius:20px;
    display:flex;
    flex-direction:column;
    justify-content:center;
    align-items:center;
    font-weight:bold;
    text-align:center;
}

.round h2{
    font-size:22px;
}

a {
    font-size: 15px;
}

h1 {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
}

@media (max-width:1167px){
    .cointainer{
    overflow-x:auto;
}

.bracket{
    display:grid;
    grid-template-columns:repeat(4,220px);
    gap:40px;
    min-width:1000px;
}
}

@view-transition {
            navigation: auto;
        }

        ::view-transition-old(root) {
            animation: fade-out .5s ease;
        }

        ::view-transition-new(root) {
            animation: fade-in .5s ease;
        }

        @keyframes fade-out {
            from { opacity: 1; }
            to { opacity: 0; }
        }

        @keyframes fade-in {
            from { opacity: 0; }
            to { opacity: 1; }
        }

</style>

<div class="cointainer"> 
<h1>NVE Bracket</h1>

<div class="bracket">

    <div class="round">
        <h2>Qualifier</h2>

        <div class="match">
        </div>
        <div class="match">
        </div>

        <h2>Loser</h2>

        <div class="match">
        </div>
    </div>

    <div class="round">
        <h2>Semi-Finals</h2>

        <div class="match">
        </div>

        <h2>Loser</h2>

        <div class="match">
        </div>
    </div>

    <div class="round">
        <h2>Finals</h2>

        <div class="match">
        </div>
    </div>

    <div class="round">
        <h2>Champion</h2>

        <div class="match">
        </div>
    </div>

</div>
</div>
        

        <script>
        async function success() {
        const bracket = await fetch("/api/bracket")
        const response = await bracket.json()

        const match1 = document.querySelectorAll(".round")[0].querySelectorAll(".match");
        const match2 = document.querySelectorAll(".round")[1].querySelectorAll(".match");
        const match3 = document.querySelectorAll(".round")[2].querySelectorAll(".match");
        const match4 = document.querySelectorAll(".round")[3].querySelectorAll(".match");

        Object.values(response.qualifier).forEach((game, index) => {
        const teams = Object.entries(game);

        match1[index].innerHTML = `
            <a>${teams[0][0]} - ${teams[0][1]}</a>
            <a>${teams[1][0]} - ${teams[1][1]}</a>
        `;
        });

        Object.values(response.semifinals).forEach((game, index) => {
        const teams = Object.entries(game);

        match2[index].innerHTML = `
            <a>${teams[0][0]} - ${teams[0][1]}</a>
            <a>${teams[1][0]} - ${teams[1][1]}</a>
        `;
        });

        Object.values(response.finals).forEach((game, index) => {
        const teams = Object.entries(game);

        match3[index].innerHTML = `
            <a>${teams[0][0]} - ${teams[0][1]}</a>
            <a>${teams[1][0]} - ${teams[1][1]}</a>
        `;
        });

        Object.values(response.champions).forEach((game, index) => {
        const teams = Object.entries(game);

        match4[index].innerHTML = `
            <a>${teams[0][0]} Champion</a>
        `;
        });

        const teams = Object.entries(response.loser.loser1);

        match1[2].innerHTML = `
            <a>${teams[0][0]} - ${teams[0][1]}</a>
            <a>${teams[1][0]} - ${teams[1][1]}</a>
        `;

        const teams2 = Object.entries(response.loser.loser2);

        match2[1].innerHTML = `
            <a>${teams2[0][0]} - ${teams2[0][1]}</a>
            <a>${teams2[1][0]} - ${teams2[1][1]}</a>
        `;

        }

        success()
        </script>

    <%- include("./partials/ball.ejs"), ({ title: title }) %>