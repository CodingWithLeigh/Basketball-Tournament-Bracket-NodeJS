<%- include("./partials/nav.ejs"), ({ title: title, status: status }) %>

<style>

body {
   text-align: center;
   padding:30px;
}

.cointainer {
   margin-top: 2%;
   background-color: #ffffff;
   border-radius: 15px;
   display: flex;
   justify-content: space-between;
   align-items: flex-start;
}

.left,
.right{
   display: flex;
   flex-direction: column;
   gap: 20px;
   margin: 2%;
}

.middle{
    position: absolute;
    left: 50%;
    top: 45%;
    transform: translateX(-50%);
    text-align: center;
}

.card {
    background-color: #f0f0f0;
    height: 120px;
    width: 300px;
    border-radius: 15px;
    display: flex;
    margin-bottom: 2%;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    font-weight: bold;
    transition:.25s;
}

.card:hover{
    transform:translateY(-5px);
    box-shadow:0 10px 20px rgba(0,0,0,.08);
}

 @view-transition {
            navigation: auto;
        }

        ::view-transition-old(root) {
            animation: fade-out .5s ease;
        }

        ::view-transition-new(root) {
            animation: fade-in .5s ease;
        }

        @keyframes fade-out {
            from { opacity: 1; }
            to { opacity: 0; }
        }

        @keyframes fade-in {
            from { opacity: 0; }
            to { opacity: 1; }
        }

</style>

<div class="cointainer">
<div class="left">
<% game.slice(0, 3).forEach(function(game, index) { %>
<div class="card">
<a> <%= game.date %> </a>
<a>Game <%= index + 1 %></a>
<a><%= game.score1 %> - <%= game.score2 %></a>
</div>
<% }) %>
</div>

<% if(series == "2-3") { %>

<div class="middle">
<h2> <%= title.replace("- Game Details", "") %> </h2>
<h2> <%= series %> </h2>
<h2> <%= team.team2 %> </h2>
<h2>Wins</h2>
</div>
<% } else if(series == "3-2") { %>
<div class="middle">
<h2> <%= title.replace("- Game Details", "") %> </h2>
<h2> <%= series %> </h2>
<h2> <%= team.team1 %> </h2>
<h2>Wins</h2>
</div>
<% } else if(series == "1-1") { %>
<div class="middle">
<h2> <%= title.replace("- Game Details", "") %> </h2>
<h2> <%= series %> </h2>
<h2> <%= team.team1 %> </h2>
<h2>Tie</h2>
</div>
<% } else if(series == "2-2") { %>
<div class="middle">
<h2> <%= title.replace("- Game Details", "") %> </h2>
<h2> <%= series %> </h2>
<h2> <%= team.team1 %> </h2>
<h2>Tie</h2>
</div>
<% } else { %>
<div class="middle">
<h2> <%= title.replace("- Game Details", "") %> </h2>
<h2> <%= series %> </h2>
</div>
<% } %>

<div class="right">
<% game.slice(3, 6).forEach(function(game, index) { %>
<div class="card">
<a> <%= game.date %> </a>
<a>Game <%= index + 4 %></a>
<a><%= game.score1 %> - <%= game.score2 %></a>
</div>
<% }) %>
</div>


</div> 

<%- include("./partials/ball.ejs"), ({ title: title }) %>
